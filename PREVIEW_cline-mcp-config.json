{
  "name": "Cline MCP Configuration",
  "description": "MCP Servers configuration for enterprise-level Vue/TypeScript development",
  "version": "1.0.0",
  "servers": [
    {
      "name": "eslint-mcp",
      "description": "ESLint code quality checking",
      "enabled": true,
      "command": "node",
      "args": ["path/to/eslint-mcp/server.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "config": {
        "rules": {
          "no-any": "error",
          "no-hardcoded-values": "error",
          "no-duplicate-code": "warn",
          "naming-convention": "error"
        }
      }
    },
    {
      "name": "typescript-mcp",
      "description": "TypeScript type checking and inference",
      "enabled": true,
      "command": "node",
      "args": ["path/to/typescript-mcp/server.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "config": {
        "strict": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
      }
    },
    {
      "name": "vue-language-server-mcp",
      "description": "Vue component analysis and validation",
      "enabled": true,
      "command": "node",
      "args": ["path/to/vue-language-server-mcp/server.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "config": {
        "validateProps": true,
        "validateEmits": true,
        "validateTemplate": true
      }
    },
    {
      "name": "git-mcp",
      "description": "Git operations and code history",
      "enabled": true,
      "command": "node",
      "args": ["path/to/git-mcp/server.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "config": {
        "showDiff": true,
        "showHistory": true
      }
    },
    {
      "name": "file-system-mcp",
      "description": "File system operations and project analysis",
      "enabled": true,
      "command": "node",
      "args": ["path/to/file-system-mcp/server.js"],
      "env": {
        "NODE_ENV": "production"
      },
      "config": {
        "maxDepth": 5,
        "ignorePatterns": ["node_modules", ".git", "dist", "build"]
      }
    }
  ],
  "capabilities": {
    "codeAnalysis": true,
    "typeChecking": true,
    "componentValidation": true,
    "gitIntegration": true,
    "fileOperations": true
  }
}
